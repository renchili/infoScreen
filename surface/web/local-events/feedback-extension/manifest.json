{
  "manifest_version": 3,
  "name": "InfoScreen Local Event Feedback",
  "version": "1.0.0",
  "description": "Mark Event cards while browsing official listing pages and submit their DOM position to InfoScreen.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {"service_worker": "service_worker.js"},
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
