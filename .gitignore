# Repository root allowlist.
# Root is for repo control/docs only; project code and local runtime state do not belong here.
/*
!/.gitignore
!/README.md
!/AGENTS.md
!/AGENT.md
!/docs/
!/docs/**
!/skills/
!/skills/**
!/surface/
!/surface/**

# Local/runtime state.
.env/
surface/.env/
logs/
.review_delete/
__pycache__/
*.pyc
*.tmp
*.log
.DS_Store

# Frontend source must live under surface/web/assets/, not directly under surface/web/.
surface/web/*.js
surface/web/*.css
!surface/web/index.html

# Local photos are runtime input, not repo root source.
photo/
photos/
public_photos/

# Unrelated local tools.
chatgpt-ui-once/
