# Repository root allowlist.
# Root is for repo control/docs/metadata/CI/operator entrypoints only; runtime state does not belong here.
/*
!/.gitignore
!/README.md
!/AGENTS.md
!/AGENT.md
!/metadata.json
!/.githooks/
!/.githooks/**
!/.github/
!/.github/**
!/docs/
!/docs/**
!/skills/
!/skills/**
!/surface/
!/surface/**
!/deploy/
!/deploy/**
!/mac/
!/mac/**
!/scripts/
!/scripts/**

# Local/runtime state.
.env/
surface/.env/
logs/
.review_delete/
__pycache__/
*.pyc
*.tmp
*.log
.DS_Store

# Mac-side local schedule sync runtime state.
mac/local.env
mac/schedule.json
mac/*.log

# Frontend source must live under surface/web/assets/, not directly under surface/web/.
surface/web/*.js
surface/web/*.css
!surface/web/index.html

# Local photos are runtime input, not repo root source.
photo/
photos/
public_photos/

# Unrelated local tools.
chatgpt-ui-once/
